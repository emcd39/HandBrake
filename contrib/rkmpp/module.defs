$(eval $(call import.MODULE.defs,RKMPP,rkmpp))
$(eval $(call import.CONTRIB.defs,RKMPP))

# GitHub mirror of gitee.com/nyanmisaka/mpp
RKMPP.FETCH.url = https://github.com/emcd39/mpp/archive/refs/heads/master.tar.gz
RKMPP.FETCH.sha256 = skip
RKMPP.FETCH.git = https://github.com/emcd39/mpp.git
RKMPP.FETCH.branch = master

RKMPP.CONFIGURE.cmd = $(NOOP)
RKMPP.BUILD.extra = PREFIX="$(RKMPP.CONFIGURE.prefix)"
RKMPP.INSTALL.extra = PREFIX="$(RKMPP.CONFIGURE.prefix)"
