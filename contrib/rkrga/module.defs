$(eval $(call import.MODULE.defs,RGA,rga))
$(eval $(call import.CONTRIB.defs,RGA))

RGA.GIT.url = https://gitee.com/nyanmisaka/rga.git
RGA.GIT.branch = master

RGA.CONFIGURE = \
    cd $(@D) && \
    cmake -B build \
    -DCMAKE_INSTALL_PREFIX=$(RGA.CONFIGURE.prefix) \
    -DCMAKE_BUILD_TYPE=Release

RGA.BUILD = \
    $(MAKE) -C $(@D)/build -j$(JOBS)

RGA.INSTALL = \
    $(MAKE) -C $(@D)/build install
